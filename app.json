{
  "expo": {
    "name": "MUBADEV Matrix",
    "slug": "mubadev",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#04111d"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.mubadev.matrix"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#04111d"
      },
      "package": "com.mubadev.matrix"
    },
    "plugins": [
      "expo-router"
    ],
    "scheme": "mubadev",
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "692f1338-a166-498c-97fc-d5f058763821"
      },
      "router": {
        "origin": false
      }
    },
    "owner": "muratasd"
  }
}
